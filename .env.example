# Supabase project credentials for Kurhona.
# Copy this file to .env and fill in your values from your Supabase project's
# API settings (https://app.supabase.com/project/_/settings/api).
# See SETUP.md section 2-3 for the full walkthrough.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# VAPID public key for the Web Push reminders feature. Generate a pair with
# `npx web-push generate-vapid-keys` and put the public half here. The
# private half lives in Supabase secrets (VAPID_PRIVATE_KEY) — never commit
# it. See SETUP.md §8.5 for the full walkthrough.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key